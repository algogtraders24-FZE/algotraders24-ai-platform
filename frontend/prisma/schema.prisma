// prisma/schema.prisma
// Sprint 14B - Prisma models mapped to Sprint 14A entity shapes.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("user")
  planId    String   @default("free")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  price     Float    @default(0)
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversation {
  id            String   @id @default(cuid())
  userId        String
  title         String
  messageCount  Int      @default(0)
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model Agent {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Automation {
  id        String   @id @default(cuid())
  userId    String
  name      String
  trigger   String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Knowledge {
  id         String   @id @default(cuid())
  userId     String
  title      String
  source     String
  chunkCount Int      @default(0)
  status     String   @default("processing")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model Billing {
  id        String   @id @default(cuid())
  userId    String
  planId    String
  status    String   @default("active")
  amount    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
